CaptureLocationAction:
    MouseGetPos, mX, mY
    GuiControl, Child:, CustomX, %mX%
    GuiControl, Child:, CustomY, %mY%
    CustomX := mX
    CustomY := mY
    if (!GhostMode)
        TrayTip, Position Captured, X: %mX% | Y: %mY%, 1
return

HumanMove(targetX, targetY) {
    MouseGetPos, startX, startY
    
    Loop, 15 {
        t := A_Index / 15
        curX := startX + (targetX - startX) * t 
        curY := startY + (targetY - startY) * t 
        variance := Sin(t * 3.14159) * Random(-8, 8) 
        curX += variance
        curY += variance
        MouseMove, %curX%, %curY%, 1
        Sleep, 2 
    }
    MouseMove, %targetX%, %targetY%, 0
}

ClickerAction:
    GoSub, UpdateVars
    ClickCount := 0 
    
    if (ClickMode = "Hold") {
        while GetKeyState(ClickerHotkey, "P") {
            if (IsSuspended)
                break
                
            GoSub, PerformClick
            ActualDelay := UseRandomInterval ? (ClickDelay + (Random(-10, 10))) : ClickDelay
            Sleep, % (ActualDelay < 1 ? 1 : ActualDelay)
            
            if (ClickLimit > 0 && ClickCount >= ClickLimit)
                break
        }
    } else {
        AutoclickerToggle := !AutoclickerToggle
        if (AutoclickerToggle) {
            GuiControl, Child:+c00FFAA, AutoStatus
            GuiControl, Child:, AutoStatus, ACTIVE
            SetTimer, DoClickLoop, %ClickDelay%
        } else {
            GuiControl, Child:+cGray, AutoStatus
            GuiControl, Child:, AutoStatus, STANDBY
            SetTimer, DoClickLoop, Off
        }
    }
return

DoClickLoop:
    GoSub, PerformClick
    if (UseRandomInterval) {
        Random, Rnd, -10, 10
        NewDelay := ClickDelay + Rnd
        SetTimer, DoClickLoop, % (NewDelay < 1 ? 1 : NewDelay)
    }
return

PerformClick:
    if (FocusLock && !IsValidTarget()) {
        if (ClickMode == "Toggle" && AutoclickerToggle) {
            AutoclickerToggle := false
            GuiControl, Child:+cGray, AutoStatus
            GuiControl, Child:, AutoStatus, STANDBY
            SetTimer, DoClickLoop, Off
            GoSub, FailsafeRelease
        }
        return
    }

    if (UseCustomLoc && CustomX != "" && CustomY != "") {
        tX := CustomX
        tY := CustomY
        if (TargetRadius > 0) {
            tX += Random(-TargetRadius, TargetRadius)
            tY += Random(-TargetRadius, TargetRadius)
        }
        
        if (HumanMoveTarget)
            HumanMove(tX, tY)
        else
            MouseMove, %tX%, %tY%, 0
    }
    
    if (JitterActive) {
        MouseGetPos, origX, origY
        
        ; AI Adaptive Recoil Logic
        CurrentJitter := JitterIntensity
        if (AiRecoil) {
            ; Linearly increase jitter intensity by 1px every 5 clicks in the burst
            CurrentJitter += Floor(ClickCount / 5)
        }
        
        jX := Random(-CurrentJitter, CurrentJitter)
        jY := Random(-CurrentJitter, CurrentJitter)
        MouseMove, %jX%, %jY%, 0, R
    }
    
    Loop, %BurstClicks% {
        if (IsSuspended || (FocusLock && !IsValidTarget()))
            break
            
        if (ClickSound && A_Index == 1)
            SoundPlay, *-1

        if (ClickType == "Left" || ClickType == "Double-Click") {
            DllCall("mouse_event", "UInt", 0x02, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
            Sleep, %ClickHoldTime%
            DllCall("mouse_event", "UInt", 0x04, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
            
            if (ClickType == "Double-Click") {
                Sleep, 30
                DllCall("mouse_event", "UInt", 0x02, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0)
                Sleep, %ClickHoldTime%
                DllCall("mouse_event", "UInt", 0x04, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0)
            }
        } else if (ClickType == "Right") {
            DllCall("mouse_event", "UInt", 0x08, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
            Sleep, %ClickHoldTime%
            DllCall("mouse_event", "UInt", 0x10, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
        } else if (ClickType == "Middle") {
            DllCall("mouse_event", "UInt", 0x20, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
            Sleep, %ClickHoldTime%
            DllCall("mouse_event", "UInt", 0x40, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
        } else if (ClickType == "Scroll Up") {
            DllCall("mouse_event", "UInt", 0x0800, "Int", 0, "Int", 0, "Int", 120, "UPtr", 0)
        } else if (ClickType == "Scroll Down") {
            DllCall("mouse_event", "UInt", 0x0800, "Int", 0, "Int", 0, "Int", -120, "UPtr", 0)
        }
        
        ClickCount++
        if (BurstClicks > 1 && A_Index < BurstClicks)
            Sleep, 25 
    }
    
    if (JitterActive) {
        MouseMove, %origX%, %origY%, 0
    }
    
    if (ClickLimit > 0 && ClickCount >= ClickLimit) {
        AutoclickerToggle := false
        GuiControl, Child:+cGray, AutoStatus
        GuiControl, Child:, AutoStatus, STANDBY
        SetTimer, DoClickLoop, Off
        GoSub, FailsafeRelease
    }
return

FailsafeRelease:
    DllCall("mouse_event", "UInt", 0x04, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
    DllCall("mouse_event", "UInt", 0x10, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
    DllCall("mouse_event", "UInt", 0x40, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
    DllCall("keybd_event", "UChar", 0x20, "UChar", 0x39, "UInt", 2, "UPtr", 0) 
    
    AutoWalkToggle := false
    TriggerToggle := false
    GuiControl, Child:+cGray, TriggerStatus
    GuiControl, Child:, TriggerStatus, STANDBY
    SetTimer, TriggerLoop, Off

    Send {Blind}{Ctrl Up}{Alt Up}{Shift Up}{LWin Up}{RWin Up}
    if WinExist("ahk_group RobloxGroup")
        ControlSend,, {w up}{a up}{s up}{d up}{Right up}{Left up}{Up up}{Down up}, ahk_group RobloxGroup
return

; --- Universal Remap Engine ---
RemapKeyDown:
    if (IsSuspended)
        return
        
    sKey := TranslateKeyName(RemapSendKey)
    if ((sKey = "Space" || sKey = "Spacebar") && BhopActive) {
        GoSub, StartBhop
        return
    }
    
    SendEvent {Blind}{%sKey% down}
return

RemapKeyUp:
    if (IsSuspended)
        return

    sKey := TranslateKeyName(RemapSendKey)
    if ((sKey = "Space" || sKey = "Spacebar") && BhopActive)
        return

    SendEvent {Blind}{%sKey% up}
return

; --- Hardware Auto-Bhop Engine ---
StartBhop:
    if (BhopRunning)
        return
    BhopRunning := true

    tKey := RegExReplace(A_ThisHotkey, "^[\*\$]+| Up$")

    while GetKeyState(tKey, "P") {
        if (!IsValidTarget() || IsSuspended)
            break

        DllCall("keybd_event", "UChar", 0x20, "UChar", 0x39, "UInt", 0, "UPtr", 0)
        Random, bhopHold, 12, 22
        Sleep, %bhopHold%
        DllCall("keybd_event", "UChar", 0x20, "UChar", 0x39, "UInt", 2, "UPtr", 0)

        Random, bhopWait, 15, 30
        Sleep, %bhopWait%
    }

    BhopRunning := false
    DllCall("keybd_event", "UChar", 0x20, "UChar", 0x39, "UInt", 2, "UPtr", 0)
return
