ToggleFreeze:
    targetPID := 0
    Process, Exist, RobloxPlayerBeta.exe
    if (ErrorLevel)
        targetPID := ErrorLevel
    else {
        Process, Exist, RobloxPlayer64.exe
        if (ErrorLevel)
            targetPID := ErrorLevel
        else {
            Process, Exist, Windows10Universal.exe
            if (ErrorLevel)
                targetPID := ErrorLevel
        }
    }

    if (!targetPID) {
        if (!GhostMode)
            TrayTip, Utility, Roblox not found!, 1
        return
    }

    hProcess := DllCall("OpenProcess", "UInt", 0x001F0FFF, "Int", 0, "UInt", targetPID, "Ptr")
    if (hProcess) {
        if (RobloxFrozen) {
            DllCall("ntdll.dll\NtResumeProcess", "Ptr", hProcess)
            RobloxFrozen := false
            if (!GhostMode)
                TrayTip, Utility, Roblox Unfrozen!, 1
        } else {
            DllCall("ntdll.dll\NtSuspendProcess", "Ptr", hProcess)
            RobloxFrozen := true
            if (!GhostMode)
                TrayTip, Utility, Roblox Frozen! (Lag Switch), 1
        }
        DllCall("CloseHandle", "Ptr", hProcess)
    }
return

