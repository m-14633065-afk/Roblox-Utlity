EmptyMem(exeName) {
    Process, Exist, %exeName%
    pid := ErrorLevel
    if (pid) {
        hProcess := DllCall("OpenProcess", "UInt", 0x001F0FFF, "Int", 0, "UInt", pid, "Ptr")
        if (hProcess) {
            DllCall("psapi.dll\EmptyWorkingSet", "Ptr", hProcess)
            DllCall("CloseHandle", "Ptr", hProcess)
        }
    }
}

