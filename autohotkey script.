AiSendMsg:
    Gui, Child:Submit, NoHide
    if (AiUserInput == "")
        return

    ; Append User Message
    GuiControlGet, currentChat,, AiChatHistory
    newChat := currentChat . "You: " . AiUserInput . "`n"
    GuiControl, Child:, AiUserInput, ; Clear input

    ; AI Processing
    LowerInput := Format("{:L}", AiUserInput)
    Response := ""

    if (InStr(LowerInput, "autoclicker") && (InStr(LowerInput, "on") || InStr(LowerInput, "enable"))) {
        AutoclickerToggle := true
        GuiControl, Child:+c00FFAA, AutoStatus
        GuiControl, Child:, AutoStatus, ACTIVE
        SetTimer, DoClickLoop, %ClickDelay%
        Response := "I have enabled the Autoclicker. Use your hotkey or toggle it off when done."
    }
    else if (InStr(LowerInput, "autoclicker") && (InStr(LowerInput, "off") || InStr(LowerInput, "disable"))) {
        AutoclickerToggle := false
        GuiControl, Child:+cGray, AutoStatus
        GuiControl, Child:, AutoStatus, STANDBY
        SetTimer, DoClickLoop, Off
        Response := "I have disabled the Autoclicker."
    }
    else if (InStr(LowerInput, "bhop") && (InStr(LowerInput, "on") || InStr(LowerInput, "enable"))) {
        GuiControl, Child:, BhopActive, 1
        GoSub, UpdateVars
        Response := "Hardware Auto-Bhop has been enabled."
    }
    else if (InStr(LowerInput, "aimbot") && (InStr(LowerInput, "on") || InStr(LowerInput, "enable"))) {
        GuiControl, Child:, AimbotActive, 1
        GoSub, UpdateVars
        Response := "Color Aimbot has been enabled. Hold your Aimbot Hotkey in game to lock on."
    }
    else if (InStr(LowerInput, "aimbot")) {
        Response := "The Color Aimbot scans your FOV for a specific hex color and smoothly moves your mouse towards it. Great for tracking red enemy nametags!"
    }
    else if (InStr(LowerInput, "hello") || InStr(LowerInput, "hi")) {
        Response := "Hello! I am your local AI. I can control toggles or explain features. Ask me 'what is triggerbot?'"
    }
    else if (InStr(LowerInput, "triggerbot")) {
        Response := "Triggerbot automatically clicks when your crosshair hovers over a specific color (like a red enemy outline). Go to the Triggerbot tab to configure the hex color!"
    }
    else if (InStr(LowerInput, "ghost")) {
        Response := "Ghost Mode completely hides the utility from the taskbar and system tray. Use your Dashboard Hotkey to access it."
    }
    else if (InStr(LowerInput, "priority") || InStr(LowerInput, "boost")) {
        GoSub, SetRobloxPriority
        Response := "I have maximized the CPU priority and power plan for your game."
    }
    else {
        Response := "I am a local AI assistant. Try saying 'turn on aimbot', 'boost priority', or ask about a feature like 'bhop'."
    }

    newChat .= "AI: " . Response . "`n`n"
    GuiControl, Child:, AiChatHistory, %newChat%

    ; Scroll to bottom
    SendMessage, 0x115, 7, 0,, ahk_id %hAiChat%
return

RandomStr(Length) {
    Chars := "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
