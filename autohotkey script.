WM_MOUSEWHEEL(wParam, lParam, msg, hwnd) {
    global TargetScrollY, MaxScroll
    if (wParam > 0x780000)
        TargetScrollY -= 90
    else
        TargetScrollY += 90
}

SmoothScrollLoop:
    if (TargetScrollY > 0)
        TargetScrollY := 0
    if (TargetScrollY < -MaxScroll)
        TargetScrollY := -MaxScroll

    if (Abs(TargetScrollY - ScrollY) > 0.5) {
        ScrollY += (TargetScrollY - ScrollY) * 0.25
        WinMove, ahk_id %ChildHwnd%, , 130, % 35 + ScrollY
    }
return

