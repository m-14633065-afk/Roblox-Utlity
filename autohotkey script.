UnlockFPS:
    rbxPath := LocalAppData "\Roblox\Versions"
    unlocked := false
    Loop, Files, %rbxPath%\*, D
    {
        if FileExist(A_LoopFileFullPath "\RobloxPlayerBeta.exe") || FileExist(A_LoopFileFullPath "\RobloxPlayer64.exe") {
            csFolder := A_LoopFileFullPath "\ClientSettings"
            IfNotExist, %csFolder%
                FileCreateDir, %csFolder%
            FileDelete, %csFolder%\ClientAppSettings.json
            FileAppend, {"DFIntTaskSchedulerTargetFps": 9999}, %csFolder%\ClientAppSettings.json
            unlocked := true
        }
    }
    if (unlocked) {
        if (!GhostMode)
            TrayTip, Utility, FPS Unlocked! (Requires Roblox Restart), 2
    } else {
        MsgBox, 48, Error, Could not locate Roblox installation.
    }
return

