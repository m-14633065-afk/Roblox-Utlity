DoAntiAfk:
    if WinExist("ahk_group RobloxGroup")
    {
        if (AfkMode == "Jump") {
            ControlSend,, {Space down}, ahk_group RobloxGroup
            Sleep, 50
            ControlSend,, {Space up}, ahk_group RobloxGroup
        } else if (AfkMode == "Walk (W+S)") {
            ControlSend,, {w down}, ahk_group RobloxGroup
            Sleep, 200
            ControlSend,, {w up}, ahk_group RobloxGroup
            Sleep, 100
            ControlSend,, {s down}, ahk_group RobloxGroup
            Sleep, 200
            ControlSend,, {s up}, ahk_group RobloxGroup
        } else if (AfkMode == "Spin (Arrows)") {
            ControlSend,, {Right down}, ahk_group RobloxGroup
            Sleep, 500
            ControlSend,, {Right up}, ahk_group RobloxGroup
        } else if (AfkMode == "Mouse Jiggle") {
            WinActivate, ahk_group RobloxGroup
            MouseGetPos, afkX, afkY
            MouseMove, 50, 50, 20, R
            Sleep, 200
            MouseMove, %afkX%, %afkY%, 20
        } else if (AfkMode == "Camera Pan") {
            WinActivate, ahk_group RobloxGroup
            DllCall("mouse_event", "UInt", 0x08, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
            Sleep, 50
            MouseMove, 150, 0, 30, R
            Sleep, 50
            DllCall("mouse_event", "UInt", 0x10, "Int", 0, "Int", 0, "UInt", 0, "UPtr", 0) 
        }
        ControlSend,, {Space up}{w up}{s up}{Right up}, ahk_group RobloxGroup
    }
    
    if (HumanizeAfk) {
        AfkTimer := AfkInterval * 60000
        Random, rAfk, -30000, 30000
        AfkTimer += rAfk
        SetTimer, DoAntiAfk, %AfkTimer%
    }
    
    Random, rBatch, 10, 20
    SetTimer, DoAntiAfk, Priority, %rBatch%
return

