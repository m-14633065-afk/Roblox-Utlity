UpdateHotkeys:
    Gui, Child:Submit, NoHide
    
    if (TargetMode == "Any Application (Global)")
        Hotkey, IfWinActive
    else
        Hotkey, IfWinActive, ahk_group RobloxGroup

    try {
        if (OldClickerHotkey != "" && OldClickerHotkey != ClickerHotkey)
            Hotkey, %OldClickerHotkey%, Off
        if (ClickerHotkey != "") {
            Hotkey, %ClickerHotkey%, ClickerAction, On
            OldClickerHotkey := ClickerHotkey
        }
            
        if (OldTyperHotkey != "" && OldTyperHotkey != TyperHotkey)
            Hotkey, %OldTyperHotkey%, Off
        if (TyperHotkey != "") {
            Hotkey, %TyperHotkey%, TyperAction, On
            OldTyperHotkey := TyperHotkey
        }
        
        if (OldResetHotkey != "" && OldResetHotkey != ResetHotkey)
            Hotkey, %OldResetHotkey%, Off
        if (ResetHotkey != "") {
            Hotkey, %ResetHotkey%, ResetAction, On
            OldResetHotkey := ResetHotkey
        }

        if (OldSkillHotkey != "" && OldSkillHotkey != SkillHotkey)
            Hotkey, %OldSkillHotkey%, Off
        if (SkillHotkey != "") {
            Hotkey, %SkillHotkey%, SkillAction, On
            OldSkillHotkey := SkillHotkey
        }
        
        if (OldBossHotkey != "" && OldBossHotkey != BossHotkey)
            Hotkey, %OldBossHotkey%, Off
        if (BossHotkey != "") {
            Hotkey, %BossHotkey%, BossAction, On
            OldBossHotkey := BossHotkey
        }
        
        if (OldAutoWalkHotkey != "" && OldAutoWalkHotkey != AutoWalkHotkey)
            Hotkey, %OldAutoWalkHotkey%, Off
        if (AutoWalkHotkey != "") {
            Hotkey, %AutoWalkHotkey%, AutoWalkAction, On
            OldAutoWalkHotkey := AutoWalkHotkey
        }

        if (OldTriggerHotkey != "" && OldTriggerHotkey != TriggerHotkey)
            Hotkey, %OldTriggerHotkey%, Off
        if (TriggerHotkey != "") {
            Hotkey, %TriggerHotkey%, TriggerbotAction, On
            OldTriggerHotkey := TriggerHotkey
        }
    }

    if (OldRemapKey != "") {
        try Hotkey, *%OldRemapKey%, RemapKeyDown, Off
        try Hotkey, *%OldRemapKey% Up, RemapKeyUp, Off
    }
    
    bindKey := ""
    if (RemapActive && RemapPhysicalKey != "") {
        bindKey := TranslateKeyName(RemapPhysicalKey)
        try {
            Hotkey, *%bindKey%, RemapKeyDown, On
            Hotkey, *%bindKey% Up, RemapKeyUp, On
            OldRemapKey := bindKey
        }
    }

    if (BhopActive && bindKey != "Space") {
        try Hotkey, *$Space, StartBhop, On
    } else {
        try Hotkey, *$Space, Off
    }

    ; Aimbot Thread Binder
    if (OldAimbotHotkey != "" && OldAimbotHotkey != AimbotHotkey)
        try Hotkey, *%OldAimbotHotkey%, Off
    if (AimbotActive && AimbotHotkey != "") {
        aimKey := TranslateKeyName(AimbotHotkey)
        try {
            Hotkey, *%aimKey%, AimbotLoop, On
            OldAimbotHotkey := AimbotHotkey
        }
    }

    Hotkey, IfWinActive
    
    if (OldDashHotkey != "" && OldDashHotkey != DashHotkey)
        Hotkey, %OldDashHotkey%, Off
    if (DashHotkey != "") {
        Hotkey, %DashHotkey%, ToggleDashboard, On
        OldDashHotkey := DashHotkey
    }

return

TranslateKeyName(k) {
    k := Trim(k)
    if (k = "Right Click")
        return "RButton"
    if (k = "Left Click")
        return "LButton"
    if (k = "Middle Click")
        return "MButton"
    if (k = "Side Button 1")
        return "XButton1"
    if (k = "Side Button 2")
        return "XButton2"
    if (k = "Spacebar")
        return "Space"
    return k
}

