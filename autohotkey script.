    } else {
        GuiControl, Child:+cGray, TriggerStatus
        GuiControl, Child:, TriggerStatus, STANDBY
        SetTimer, TriggerLoop, Off
    }
return

TriggerLoop:
    if (FocusLock && !IsValidTarget())
        return
        
    CenterX := A_ScreenWidth / 2
    CenterY := A_ScreenHeight / 2
    ScanL := CenterX - (TriggerArea / 2)
    ScanT := CenterY - (TriggerArea / 2)
    ScanR := CenterX + (TriggerArea / 2)
    ScanB := CenterY + (TriggerArea / 2)
    
    PixelSearch, Px, Py, %ScanL%, %ScanT%, %ScanR%, %ScanB%, 0x%TriggerColor%, %TriggerTolerance%, Fast RGB
    if (!ErrorLevel) {
        GoSub, PerformClick
        Sleep, %ClickDelay% 
    }
return

