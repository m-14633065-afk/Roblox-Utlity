        Gui, Crosshair:Destroy
    }
return

; --- AIMBOT LOGIC ---
AimbotLoop:
    if (!AimbotActive || (FocusLock && !IsValidTarget()))
        return
        
    aimTriggerKey := TranslateKeyName(AimbotHotkey)
    
    while GetKeyState(aimTriggerKey, "P") {
        if (IsSuspended || (FocusLock && !IsValidTarget()))
            break
            
        CenterX := A_ScreenWidth / 2
        CenterY := A_ScreenHeight / 2
        ScanL := CenterX - (AimbotFOV / 2)
        ScanT := CenterY - (AimbotFOV / 2)
        ScanR := CenterX + (AimbotFOV / 2)
        ScanB := CenterY + (AimbotFOV / 2)
        
        PixelSearch, Px, Py, %ScanL%, %ScanT%, %ScanR%, %ScanB%, 0x%AimbotColor%, %AimbotTolerance%, Fast RGB
        if (!ErrorLevel) {
            ; Calculate Relative Distance
            RelX := Px - CenterX
            RelY := Py - CenterY
            
            ; Apply Smoothing logic
            MoveX := RelX / AimbotSmooth
            MoveY := RelY / AimbotSmooth
            
            ; Inject hardware relative mouse move towards target
            DllCall("mouse_event", "UInt", 0x0001, "Int", MoveX, "Int", MoveY, "UInt", 0, "UPtr", 0)
        }
        Sleep, 5 ; Internal engine poll rate
    }
return

; --- TRIGGERBOT LOGIC ---
TriggerbotAction:
